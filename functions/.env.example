# ============= CONFIGURATION ENVIRONNEMENT =============
# Copiez ce fichier en .env et ajustez les valeurs

# Environnement principal (development | staging | production)
ENVIRONMENT=development
NODE_ENV=development

# ============= VARIABLES FIREBASE =============
# Configuration Firebase
FIREBASE_PROJECT_ID=kidai-dev
FIREBASE_DATABASE_URL=https://kidai-dev-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=kidai-dev.appspot.com

# Émulateurs locaux (développement uniquement)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_DATABASE_EMULATOR_HOST=localhost:9000
FIRESTORE_EMULATOR_HOST=localhost:8080

# ============= SERVICES EXTERNES =============
# Slack
DEV_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/DEV/WEBHOOK
STAGING_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/STAGING/WEBHOOK
PROD_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/PROD/WEBHOOK

# Email
EMAIL_SERVICE=dev
EMAIL_API_KEY=your_email_api_key_here
EMAIL_FROM=noreply@kidai.com

# Analytics
ANALYTICS_SERVICE=dev
ANALYTICS_TRACKING_ID=GA-DEV-123456

# ============= MONITORING =============
# Monitoring
MONITORING_ENABLED=true
MONITORING_LOG_LEVEL=debug
MONITORING_ALERTING=false

# Slack pour les alertes
SLACK_ALERTS_ENABLED=false
SLACK_ALERTS_CHANNEL=#alerts

# Webhook pour les alertes
MONITORING_WEBHOOK_URL=https://api.kidai.com/webhooks/monitoring
WEBHOOK_AUTH_TOKEN=your_webhook_auth_token

# ============= CONTRÔLE DES COÛTS =============
# Limites d'appels
COST_CONTROL_ENABLED=false
COST_DAILY_CALLS=10000
COST_MONTHLY_CALLS=100000

# Limites Firestore
COST_DAILY_READS=5000
COST_MONTHLY_READS=100000
COST_DAILY_WRITES=2000
COST_MONTHLY_WRITES=50000

# Blocage
COST_BLOCK_DURATION=300000
COST_MAX_VIOLATIONS=3

# Coûts Firestore
FIRESTORE_READ_COST=0.06
FIRESTORE_WRITE_COST=0.18
FIRESTORE_DELETE_COST=0.02

# ============= RATE LIMITING =============
# Configuration du rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STRICT=false
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Limites par fonction
RATE_LIMIT_ADDXP_MINUTE=10
RATE_LIMIT_ADDXP_HOUR=100
RATE_LIMIT_COMPLETE_MISSION_MINUTE=5
RATE_LIMIT_COMPLETE_MISSION_HOUR=50
RATE_LIMIT_CHECK_BADGES_MINUTE=20
RATE_LIMIT_CHECK_BADGES_HOUR=200

# ============= CACHE =============
# Configuration du cache
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Redis (optionnel)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============= TEST MODE =============
# Mode test (TOUJOURS FALSE EN PRODUCTION)
TEST_MODE_ENABLED=true
TEST_MODE_BYPASS=true
TEST_MODE_ADMIN=true
TEST_MODE_DEBUG=true
TEST_MODE_MOCK=true
TEST_MODE_SKIP_AUTH=false

# ============= FEATURES =============
# Feature flags
FEATURE_NEW_UI=true
FEATURE_BETA_FEATURES=true
FEATURE_DEBUG_TOOLS=true
FEATURE_ANALYTICS=false

# ============= SÉCURITÉ =============
# Clés secrètes
JWT_SECRET=your_jwt_secret_here
API_SECRET=your_api_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Configuration CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============= DÉBOGAGE =============
# Niveau de log
LOG_LEVEL=debug
VERBOSE_LOGGING=true

# Mode débogage
DEBUG_MODE=true
DEBUG_SQL=false
DEBUG_FIRESTORE=false

# ============= DÉPLOIEMENT =============
# Configuration de déploiement
DEPLOY_REGION=europe-west1
DEPLOY_RUNTIME=nodejs18

# Timeout des fonctions
FUNCTION_TIMEOUT=540000

# Mémoire des fonctions
FUNCTION_MEMORY=256MB

# ============= BASES DE DONNÉES EXTERNES =============
# PostgreSQL (optionnel)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kidai_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# MongoDB (optionnel)
MONGODB_URI=mongodb://localhost:27017/kidai_dev

# Redis (optionnel)
REDIS_URI=redis://localhost:6379/0

# ============= SERVICES TIERS =============
# API externe
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your_external_api_key

# Service de paiement
PAYMENT_SERVICE=stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# Service de stockage
STORAGE_SERVICE=firebase
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=kidai-storage

# ============= MONITORING AVANCÉ =============
# New Relic
NEW_RELIC_LICENSE_KEY=your_new_relic_key
NEW_RELIC_APP_NAME=kidai

# DataDog
DATADOG_API_KEY=your_datadog_key
DATADOG_APP_KEY=your_datadog_app_key

# Sentry
SENTRY_DSN=https://your_sentry_dsn
SENTRY_ENVIRONMENT=development
