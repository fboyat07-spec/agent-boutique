{
  "name": "kidai-functions",
  "version": "1.0.0",
  "description": "Firebase Functions pour KidAI avec tests automatisés",
  "main": "index.js",
  "scripts": {
    "build": "npm run lint && npm run test",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run serve",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint functions/**/*.js",
    "lint:fix": "eslint functions/**/*.js --fix",
    "format": "prettier --write functions/**/*.js",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:ci": "jest --config jest.config.js --coverage --ci --watchAll=false",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --config jest.config.js --runInBand",
    "test:specific": "jest --config jest.config.js --testNamePattern",
    "test:verbose": "jest --config jest.config.js --verbose",
    "test:clear": "jest --config jest.config.js --clearCache",
    "validate": "npm run lint && npm run test:ci",
    "pretest": "npm run lint",
    "posttest": "npm run test:coverage"
  },
  "dependencies": {
    "firebase-admin": "^11.0.0",
    "firebase-functions": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^2.8.0",
    "supertest": "^6.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "firebase",
    "functions",
    "testing",
    "jest",
    "kidai"
  ],
  "author": "KidAI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kidai/functions"
  },
  "bugs": {
    "url": "https://github.com/kidai/functions/issues"
  },
  "homepage": "https://github.com/kidai/functions#readme",
  "private": true
}
