    "admin": "^1.4.1",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.2.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^7.6.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.8",
    "openai": "^4.104.0",
    "redis": "^5.12.1",
    "stripe": "^22.1.1",
    "uuid": "^9.0.1"
